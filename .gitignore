# =====================================
# 운영용 배포 환경용 .gitignore
# 스택: TypeScript & Next.js
# =====================================

# ---------------------
# Node dependencies
# ---------------------
/node_modules
/.pnp
.pnp.*
/.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---------------------
# Build output
# ---------------------
/.next/        # Next.js 빌드 폴더
/out/          # Next.js export output
/build         # 일반 빌드 폴더

# ---------------------
# Testing
# ---------------------
/coverage

# ---------------------
# Misc
# ---------------------
.DS_Store
*.pem          # 인증서 파일

# ---------------------
# Debug logs
# ---------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---------------------
# Environment files
# ---------------------
.env*          # 필요 시 커밋 가능

# ---------------------
# Vercel deployment
# ---------------------
.vercel

# ---------------------
# TypeScript
# ---------------------
*.tsbuildinfo
next-env.d.ts

# ---------------------
# Markdown files (ignore docs)
# ---------------------
*.md